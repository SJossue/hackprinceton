# Rewind environment variables — shared template
# Usage:
#   Backend/Pi: cp .env.example backend/.env  (the FastAPI server reads this via python-dotenv)
#   Frontend:   cp .env.example frontend/.env.local  (Next.js reads NEXT_PUBLIC_* vars)
# NEVER commit a real .env / .env.local file.

# -- Backend: LLM keys --------------------------------------------------------
# Anthropic (Claude 4.7 — failover + Eragon caregiver-SMS drafting)
ANTHROPIC_API_KEY=sk-ant-...

# K2 Think V2 (primary for MBZUAI track; get from the MBZUAI WhatsApp group).
# Leave both empty until you have real credentials — the backend treats empty
# *and* "..."-placeholder values as unconfigured and routes to Claude.
K2_ENDPOINT=
K2_API_KEY=

# -- Frontend: API base URL ---------------------------------------------------
# Point this at the Pi's IP on the local network (e.g. http://pi.local:8000
# or http://192.168.x.y:8000). Must include http:// scheme.
NEXT_PUBLIC_REWIND_API=http://localhost:8000
